# Optional local auth for /v1/messages.
# If set, clients must send the same value as Bearer token or x-api-key.
CLI_PROXY_API_KEY=

# Account registry directory. Do not commit the real directory.
CLI_PROXY_AUTH_DIR=~/.cli-proxy-api

# CLI paths, if not on PATH.
CLAUDE_CLI_BIN=claude
CODEX_CLI_BIN=codex
GROK_CLI_BIN=grok
COPILOT_CLI_BIN=copilot
ANTIGRAVITY_CLI_BIN=agy

# Timeout for blocking CLI calls, in seconds.
AGENT_LLM_CLI_TIMEOUT=600

# Antigravity direct HTTP options.
ANTIGRAVITY_PROJECT_ID=
ANTIGRAVITY_CLOUDCODE_ENDPOINT=
ANTIGRAVITY_DISABLE_CLI_FALLBACK=0

# Only needed if you want direct HTTP token refresh.
ANTIGRAVITY_OAUTH_CLIENT_ID=
ANTIGRAVITY_OAUTH_CLIENT_SECRET=
